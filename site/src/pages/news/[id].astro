---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { id: article.id.split('/')[0] },
    props: { article },
  }));
}

const { article } = Astro.props;
const dateId = article.id.split('/')[0];
const { Content } = await render(article);

const debates = await getCollection('debates');
const debate = debates.find((d) => d.id.split('/')[0] === dateId);
const DebateContent = debate ? (await render(debate)).Content : null;

const guests = await getCollection('guests');
const guest = guests.find((g) => g.id.split('/')[0] === dateId);
const GuestContent = guest ? (await render(guest)).Content : null;

function formatDate(d: Date) {
  return `${d.getFullYear()}년 ${d.getMonth() + 1}월 ${d.getDate()}일`;
}
---
<Base title={article.data.title} description={article.data.summary}>
  <article>
    <p class="date">{formatDate(article.data.date)}</p>
    <h1>{article.data.title}</h1>
    <Content />
  </article>

  {DebateContent && (
    <details>
      <summary>편집국 토론 전문 보기</summary>
      <div class="debate"><DebateContent /></div>
    </details>
  )}

  {GuestContent && (
    <details>
      <summary>오늘의 객원 {article.data.guest && `— ${article.data.guest}`} (페르소나 전문)</summary>
      <div class="debate"><GuestContent /></div>
    </details>
  )}
</Base>

<style>
  .date { color: var(--muted); font-size: 0.9rem; margin-bottom: 0; }
  article h1 { margin-top: 0.25rem; font-size: 1.7rem; }
  .debate { font-size: 0.95rem; }
</style>
