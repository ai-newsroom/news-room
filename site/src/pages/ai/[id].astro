---
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { getApprovedAiPublications } from '../../lib/approvedAiPublications';

export async function getStaticPaths() {
  return (await getApprovedAiPublications()).map((publication) => ({
    params: { id: publication.id },
    props: publication,
  }));
}

const { article, release } = Astro.props;
const { Content } = await render(article);
const base = import.meta.env.BASE_URL;

function formatDate(d: Date) {
  return `${d.getFullYear()}년 ${d.getMonth() + 1}월 ${d.getDate()}일`;
}
---
<Base title={article.data.title} description={article.data.summary}>
  <nav class="edition-nav" aria-label="AI News 이동">
    <a href={`${base}/ai/`}>AI News</a>
    <a href={base}>시사판</a>
  </nav>

  <article class="technical-article">
    <p class="date">{formatDate(article.data.date)} · AI News</p>
    <h1>{article.data.title}</h1>
    <p class="release-note">
      공개 승인 완료 · 근거 상한 {article.data.evidence_ceiling} · 재현성 {article.data.reproducibility}
      · 발행 ID {release.data.publication_id}
    </p>
    <Content />
  </article>
</Base>

<style>
  .edition-nav { display: flex; gap: 1rem; margin-bottom: 1.5rem; font-size: 0.9rem; }
  .date { color: var(--muted); font-size: 0.9rem; margin-bottom: 0; }
  article h1 { margin-top: 0.25rem; font-size: 1.7rem; }
  .release-note {
    border-block: 1px solid var(--rule);
    color: var(--muted);
    font-size: 0.85rem;
    padding: 0.6rem 0;
    margin-bottom: 2rem;
  }
  .technical-article :global(table) {
    display: block;
    overflow-x: auto;
    border-collapse: collapse;
    font-size: 0.88rem;
  }
  .technical-article :global(th), .technical-article :global(td) {
    border: 1px solid var(--rule);
    padding: 0.5rem;
    vertical-align: top;
  }
</style>
