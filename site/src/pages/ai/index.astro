---
import Base from '../../layouts/Base.astro';
import { getApprovedAiPublications } from '../../lib/approvedAiPublications';

const base = import.meta.env.BASE_URL;
const publications = await getApprovedAiPublications();

function formatDate(d: Date) {
  return `${d.getFullYear()}년 ${d.getMonth() + 1}월 ${d.getDate()}일`;
}
---
<Base title="AI News" description="원문과 재현 범위를 함께 기록하는 AI 기술 뉴스">
  <nav class="edition-nav" aria-label="AI News 이동">
    <a href={`${base}/ai/`} aria-current="page">AI News</a>
    <a href={base}>시사판</a>
  </nav>

  <h1>AI News</h1>
  <p class="dek">
    모델·평가·시스템의 변화를 원문, 버전, 재현 범위와 함께 검증합니다.
    사람이 공개를 승인한 기술 기사만 이 목록에 표시됩니다.
  </p>

  <ul class="feed">
    {publications.map(({ id, article }) => (
      <li class="item">
        <p class="date">{formatDate(article.data.date)}</p>
        <h2><a href={`${base}/ai/${id}/`}>{article.data.title}</a></h2>
        <p class="summary">{article.data.summary}</p>
        <p class="evidence">
          근거 상한 {article.data.evidence_ceiling} · 재현성 {article.data.reproducibility}
        </p>
      </li>
    ))}
  </ul>
</Base>

<style>
  .edition-nav { display: flex; gap: 1rem; margin-bottom: 1.5rem; font-size: 0.9rem; }
  .edition-nav a[aria-current='page'] { font-weight: 700; }
  h1 { margin-bottom: 0.5rem; }
  .dek { color: var(--muted); margin-top: 0; }
  .feed { list-style: none; padding: 0; margin: 2rem 0 0; }
  .item { padding: 1.5rem 0; border-top: 1px solid var(--rule); }
  .item .date, .item .evidence { color: var(--muted); font-size: 0.85rem; }
  .item .date { margin: 0; }
  .item h2 { margin: 0.25rem 0; font-size: 1.35rem; }
  .item h2 a { color: var(--ink); text-decoration: none; }
  .item h2 a:hover { color: var(--accent); }
  .item .summary, .item .evidence { margin: 0.35rem 0 0; }
</style>
